<?php
declare(strict_types=1);

const APP_PASSWORD = 'ChangeThisNow123!';
const BASE_DIR = '/var/www/html';   // start here
const MAX_FILE_SIZE = 50 * 1024 * 1024;

session_start();

function h(string $value): string {
    return htmlspecialchars($value, ENT_QUOTES, 'UTF-8');
}

function isLoggedIn(): bool {
    return !empty($_SESSION['logged_in']);
}

function normalizeRelativePath(string $path): string {
    $path = str_replace(['\\', "\0"], ['/', ''], $path);
    $path = preg_replace('#/+#', '/', $path);
    return trim((string)$path, '/');
}

function pathInsideBase(string $relative = ''): ?string {
    $base = realpath(BASE_DIR);
    if ($base === false) {
        return null;
    }

    $relative = normalizeRelativePath($relative);
    $target = $base . ($relative !== '' ? DIRECTORY_SEPARATOR . $relative : '');

    if (!file_exists($target)) {
        return null;
    }

    $real = realpath($target);
    if ($real === false) {
        return null;
    }

    if ($real === $base || strpos($real, $base . DIRECTORY_SEPARATOR) === 0) {
        return $real;
    }

    return null;
}

function currentRelativePath(): string {
    $path = isset($_GET['path']) ? (string)$_GET['path'] : '';
    $path = normalizeRelativePath($path);

    $full = pathInsideBase($path);
    if ($full === null || !is_dir($full)) {
        return '';
    }

    return $path;
}

function listItems(string $dir): array {
    $items = [];
    $scan = scandir($dir);
    if ($scan === false) {
        return $items;
    }

    foreach ($scan as $name) {
        if ($name === '.' || $name === '..') {
            continue;
        }

        $full = $dir . DIRECTORY_SEPARATOR . $name;
        $items[] = [
            'name' => $name,
            'full' => $full,
            'is_dir' => is_dir($full),
            'size' => is_file($full) ? filesize($full) : 0,
            'mtime' => filemtime($full) ?: 0,
        ];
    }

    usort($items, function ($a, $b) {
        if ($a['is_dir'] !== $b['is_dir']) {
            return $a['is_dir'] ? -1 : 1;
        }
        return strcasecmp($a['name'], $b['name']);
    });

    return $items;
}

function formatBytes(int $bytes): string {
    $units = ['B', 'KB', 'MB', 'GB', 'TB'];
    $i = 0;
    $size = (float)$bytes;

    while ($size >= 1024 && $i < count($units) - 1) {
        $size /= 1024;
        $i++;
    }

    return round($size, 2) . ' ' . $units[$i];
}

function sendFileDownload(string $fullPath, ?string $downloadName = null): void {
    if (!is_file($fullPath) || !is_readable($fullPath)) {
        http_response_code(404);
        exit('File not found.');
    }

    $downloadName ??= basename($fullPath);

    header('Content-Type: application/octet-stream');
    header('Content-Disposition: attachment; filename="' . rawurlencode($downloadName) . '"');
    header('Content-Length: ' . filesize($fullPath));

    while (ob_get_level()) {
        ob_end_clean();
    }

    readfile($fullPath);
    exit;
}

function zipFolder(string $folderPath): ?string {
    if (!class_exists('ZipArchive')) {
        return null;
    }

    $folderPath = realpath($folderPath);
    if ($folderPath === false) {
        return null;
    }

    $tmpZip = tempnam(sys_get_temp_dir(), 'zip_');
    if ($tmpZip === false) {
        return null;
    }

    $zip = new ZipArchive();
    if ($zip->open($tmpZip, ZipArchive::OVERWRITE) !== true) {
        @unlink($tmpZip);
        return null;
    }

    $rootName = basename($folderPath);

    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($folderPath, FilesystemIterator::SKIP_DOTS),
        RecursiveIteratorIterator::SELF_FIRST
    );

    foreach ($iterator as $item) {
        $itemPath = $item->getRealPath();
        if ($itemPath === false) {
            continue;
        }

        $localName = $rootName . '/' . ltrim(str_replace('\\', '/', substr($itemPath, strlen($folderPath))), '/');

        if ($item->isDir()) {
            $zip->addEmptyDir($localName);
        } else {
            $zip->addFile($itemPath, $localName);
        }
    }

    $zip->close();
    return $tmpZip;
}
